# Crucible — example environment file.
# Copy to `.env` and fill in. SECRETS ONLY — structural config goes in crucible.yaml.

# Anthropic API key — required when orchestrator.name = claude_tools (default).
# In Phase 3 crowdsourced deployments the orchestrator runs centrally; volunteers
# do NOT need this.
ANTHROPIC_API_KEY=

# Materials Project API key — required when materials_project.enabled = true.
# Get one at https://next-gen.materialsproject.org/api
MP_API_KEY=

# GPU selection on multi-GPU hosts. Comma-separated indices, e.g. "0" or "0,1".
# Leave blank to use all visible GPUs.
CUDA_VISIBLE_DEVICES=

# Override `run.output_dir` from crucible.yaml. Optional.
CRUCIBLE_OUTPUT_DIR=
